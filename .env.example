# Azure AI Foundry - copy to .env and fill in your values
# cp .env.example .env

# Agent reference (name:version)
AZURE_EXISTING_AGENT_ID=hr-policy:1

# Environment / playground
AZURE_ENV_NAME=agents-playground-3161
AZURE_LOCATION=eastus2

# Subscription
AZURE_SUBSCRIPTION_ID=your-subscription-id

# AI Project endpoint (from Foundry project)
AZURE_EXISTING_AIPROJECT_ENDPOINT=https://your-account.services.ai.azure.com/api/projects/your-project

# Resource IDs (from Azure portal / Foundry)
AZURE_EXISTING_AIPROJECT_RESOURCE_ID=/subscriptions/.../resourceGroups/.../providers/Microsoft.CognitiveServices/accounts/.../projects/...
AZURE_EXISTING_RESOURCE_ID=/subscriptions/.../resourceGroups/.../providers/Microsoft.CognitiveServices/accounts/...

# Allow non-empty folder (for azd)
AZD_ALLOW_NON_EMPTY_FOLDER=true
